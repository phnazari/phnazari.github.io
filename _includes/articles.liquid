<div class="news">
  {% if site.articles != blank %}
    {% assign articles_size = site.articles | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.articles.scrollable and articles_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign articles = site.articles | reverse %}
        {% if include.limit and page.articles.limit %}
          {% assign articles_limit = page.articles.limit %}
        {% else %}
          {% assign articles_limit = articles_size %}
        {% endif %}
        {% for item in articles limit: articles_limit %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No articles so far...</p>
  {% endif %}
</div>
